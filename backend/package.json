    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.22.1",
    "morgan": "1.11.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.9",
