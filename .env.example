# ============================================================
# OmniPay - Variables d'Environnement
# Copiez ce fichier en .env.local pour le développement
# Ne jamais committer les vraies clés dans le dépôt !
# ============================================================

# --- Base de données (Vercel Postgres) ---
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- Environnement ---
NODE_ENV=development

# ============================================================
# GATEWAYS DE PAIEMENT
# ============================================================

# --- Stripe ---
# Tableau de bord : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- PayDunya (Afrique de l'Ouest) ---
# Tableau de bord : https://app.paydunya.com/
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
# Mode : 'test' ou 'live'
PAYDUNYA_MODE=test

# --- Flutterwave (Afrique) ---
# Tableau de bord : https://dashboard.flutterwave.com/
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_hash

# --- Paystack (Nigeria, Ghana, Kenya, Afrique du Sud) ---
# Tableau de bord : https://dashboard.paystack.com/
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...

# --- Coinbase Commerce (Cryptomonnaies) ---
# Tableau de bord : https://commerce.coinbase.com/
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# ============================================================
# APPLICATION
# ============================================================

# URL de l'application (sans slash final)
APP_URL=https://omnipay-eu.com

# Clé secrète pour JWT / sessions (32 caractères minimum)
SESSION_SECRET=changez_cette_cle_secrete_en_production

# Secret requis pour appeler /api/init-db
INIT_DB_SECRET=changez_ce_secret_init_db_en_production

# ============================================================
# RATE LIMITING
# ============================================================

# Nombre max de requêtes par fenêtre (par IP)
RATE_LIMIT_MAX=100
# Durée de la fenêtre en millisecondes (15 minutes)
RATE_LIMIT_WINDOW_MS=900000
