<!-- SCREEN: TERMINAL PRO -->
<div id="screen-terminal" class="screen">
  <div class="terminal-app">
    <!-- SIDEBAR TERMINAL -->
    <aside class="t-sidebar">
      <div class="t-logo">
        <span style="font-size:18px;color:#818cf8">⬡</span>
        <span class="t-logo-text">OmniPay Pro</span>
      </div>
      <nav class="t-nav">
        <button class="t-btn active" onclick="showTPanel('t-dashboard',this)"><span>◈</span> <span>Tableau de bord</span></button>
        <button class="t-btn" onclick="showTPanel('t-pay',this)"><span>▶</span> <span>Payer/Encaisser</span></button>
        <button class="t-btn" onclick="showTPanel('t-crypto',this)"><span>₿</span> <span>Crypto</span></button>
        <button class="t-btn" onclick="showTPanel('t-receive',this)"><span>↓</span> <span>Recevoir</span></button>
        <button class="t-btn" onclick="showTPanel('t-gift',this)"><span>◎</span> <span>Cartes cadeaux</span></button>
        <button class="t-btn" onclick="showTPanel('t-history',this)"><span>≡</span> <span>Historique</span></button>
        <button class="t-btn" onclick="showTPanel('t-settings',this)"><span>⚙</span> <span>Paramètres</span></button>
        <button class="t-btn" onclick="showScreen('admin')" style="margin-top:auto"><span>←</span> <span>Retour Admin</span></button>
      </nav>
      <div style="padding:12px 14px;border-top:1px solid rgba(255,255,255,.08)">
        <div style="font-size:10px;color:#6ee7b7">🔒 E2EE · PCI DSS L1</div>
        <div style="font-size:9px;color:rgba(255,255,255,.3);margin-top:2px">v2.0 · OMNIPAY</div>
      </div>
    </aside>
    <!-- MAIN TERMINAL -->
    <main class="t-main">
      <div class="t-topbar">
        <span class="t-title" id="t-page-title">Tableau de bord</span>
        <div style="display:flex;align-items:center;gap:6px">
          <span class="t-badge t-badge-green">● Connecté</span>
          <span class="t-badge t-badge-blue">Ecobank</span>
          <span class="t-badge t-badge-amber">KYC ✓</span>
          <div style="width:30px;height:30px;border-radius:50%;background:#4f46e5;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px">R</div>
        </div>
      </div>

      <!-- T-DASHBOARD -->
      <div id="t-dashboard" class="t-panel active">
        <div class="t-stats-grid">
          <div class="t-stat"><div class="t-stat-label">Volume aujourd'hui</div><div class="t-stat-value">€ 3 840</div><div class="t-stat-change">+12% vs hier</div></div>
          <div class="t-stat"><div class="t-stat-label">Transactions</div><div class="t-stat-value">47</div><div class="t-stat-change">+5 ce matin</div></div>
          <div class="t-stat"><div class="t-stat-label">Crypto reçu</div><div class="t-stat-value">€ 640</div><div class="t-stat-change">BTC + ETH</div></div>
          <div class="t-stat"><div class="t-stat-label">Taux succès</div><div class="t-stat-value">99.2%</div><div class="t-stat-change">Excellent</div></div>
        </div>
        <div class="t-grid-2">
          <div class="t-card">
            <div class="t-card-title">Méthodes actives</div>
            <div id="t-method-list"></div>
          </div>
          <div class="t-card">
            <div class="t-card-title">Dernières transactions</div>
            <div id="mini-tx"></div>
          </div>
        </div>
      </div>

      <!-- T-PAY -->
      <div id="t-pay" class="t-panel">
        <div class="t-grid-2">
          <div class="t-card">
            <div class="t-card-title">Payer / Encaisser</div>
            <div id="t-pay-form">
              <div class="t-amount-hero"><div class="t-amount-label">Montant</div><div class="t-amount-big" id="t-amount-display">€ 0,00</div></div>
              <div class="t-form-group">
                <label>Montant</label>
                <div style="display:grid;grid-template-columns:1fr auto;gap:6px">
                  <input type="number" id="t-pay-amount" placeholder="0.00" oninput="tUpdateAmount()">
                  <select id="t-pay-currency" onchange="tUpdateAmount()" style="width:auto;min-width:80px">
                    <option>EUR</option><option>USD</option><option>GBP</option><option>XOF</option>
                  </select>
                </div>
              </div>
              <div class="t-form-group"><label>Méthode de paiement</label>
                <div class="t-method-grid">
                  <div class="t-m-tile selected" onclick="tSelMethod(this)"><div class="t-m-icon">💳</div><div class="t-m-name">CB/Visa</div></div>
                  <div class="t-m-tile" onclick="tSelMethod(this)"><div class="t-m-icon">🔵</div><div class="t-m-name">PayPal</div></div>
                  <div class="t-m-tile" onclick="tSelMethod(this)"><div class="t-m-icon">🏦</div><div class="t-m-name">SEPA</div></div>
                  <div class="t-m-tile" onclick="tSelMethod(this)"><div class="t-m-icon">📱</div><div class="t-m-name">MoMo</div></div>
                  <div class="t-m-tile" onclick="tSelMethod(this)"><div class="t-m-icon">🏦</div><div class="t-m-name">Wise</div></div>
                  <div class="t-m-tile" onclick="tSelMethod(this)"><div class="t-m-icon">🟠</div><div class="t-m-name">Orange</div></div>
                  <div class="t-m-tile" onclick="tSelMethod(this)"><div class="t-m-icon">💵</div><div class="t-m-name">W.Union</div></div>
                  <div class="t-m-tile" onclick="tSelMethod(this)"><div class="t-m-icon">₿</div><div class="t-m-name">Crypto</div></div>
