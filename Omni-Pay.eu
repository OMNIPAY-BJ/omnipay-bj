<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Omnipay-Bénin | Fintech Africaine Mondiale</title>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0A1628;--navy2:#132240;--blue:#1A56DB;--green:#00C896;
  --gold:#F4A726;--white:#fff;--gray:#8A9BB0;--light:#F0F4FF;
  --red:#DC2626;--indigo:#4f46e5;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--navy);color:white;overflow-x:hidden}
input,select,button,textarea{font-family:inherit;font-size:14px;outline:none}

/* SCREENS */
.screen{display:none}
.screen.active{display:block}

/* NAV */
nav{background:rgba(10,22,40,0.97);backdrop-filter:blur(10px);padding:0 20px;position:sticky;top:0;z-index:100;border-bottom:1px solid rgba(0,200,150,0.2);height:58px;display:flex;align-items:center;justify-content:space-between}
.logo{font-size:20px;font-weight:900;cursor:pointer}
.logo span{color:var(--green)}
.logo small{color:var(--gold);font-size:10px;margin-left:3px}
.nav-links{display:flex;gap:6px;align-items:center}
.lang-btn{background:rgba(255,255,255,0.08);border:none;color:var(--gray);padding:4px 9px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:700}
.lang-btn.active{background:var(--green);color:white}
.nav-btn{background:var(--blue);color:white;border:none;padding:7px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px}

/* TICKER */
.ticker-wrap{background:var(--navy2);padding:7px 0;overflow:hidden;border-bottom:1px solid rgba(255,255,255,0.05)}
.ticker{display:flex;gap:40px;white-space:nowrap;animation:ticker 30s linear infinite}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.ticker span{color:var(--gold);font-size:11px;font-weight:500}

/* HERO */
.hero{background:linear-gradient(135deg,#020B1A 0%,#0A1628 50%,#0D2B1A 100%);padding:60px 20px 50px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 30% 50%,rgba(0,200,150,0.06),transparent 60%),radial-gradient(circle at 70% 20%,rgba(26,86,219,0.08),transparent 50%)}
.hero-badge{display:inline-block;background:rgba(244,167,38,0.15);color:var(--gold);padding:4px 14px;border-radius:20px;font-size:11px;font-weight:700;margin-bottom:18px;border:1px solid rgba(244,167,38,0.3)}
.hero h1{font-size:clamp(40px,8vw,72px);font-weight:900;letter-spacing:-2px;line-height:1;margin-bottom:10px}
.hero h1 span{color:var(--green)}
.hero-sub{color:rgba(255,255,255,0.65);font-size:clamp(14px,3vw,18px);margin-bottom:6px}
.hero-sub2{color:var(--green);font-size:13px;font-weight:600;margin-bottom:32px}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:36px}
.btn-primary{background:linear-gradient(135deg,var(--green),#00A87E);color:white;padding:13px 28px;border-radius:10px;border:none;font-weight:700;font-size:14px;cursor:pointer;transition:all .2s}
.btn-secondary{background:rgba(255,255,255,0.08);color:white;padding:13px 28px;border-radius:10px;border:1px solid rgba(255,255,255,0.2);font-weight:600;font-size:14px;cursor:pointer}
.btn-gold{background:linear-gradient(135deg,var(--gold),#D4891A);color:var(--navy);padding:13px 28px;border-radius:10px;border:none;font-weight:700;font-size:14px;cursor:pointer}
.btn-danger{background:var(--red);color:white;padding:8px 16px;border-radius:8px;border:none;cursor:pointer;font-weight:600;font-size:12px}

/* CONVERTER */
.converter{background:rgba(255,255,255,0.05);border:1px solid rgba(0,200,150,0.25);border-radius:14px;padding:20px;max-width:460px;margin:0 auto}
.conv-h{color:var(--gold);font-size:11px;font-weight:700;margin-bottom:14px;text-align:left}
.conv-row{display:grid;grid-template-columns:2fr 1fr;gap:8px;margin-bottom:8px}
.conv-input{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:white;padding:10px 12px;border-radius:8px;font-size:16px;font-weight:700;width:100%}
.conv-select{background:var(--navy2);border:1px solid rgba(255,255,255,0.15);color:white;padding:10px 12px;border-radius:8px;font-size:13px;width:100%}
.conv-select option{background:var(--navy2)}
.conv-result{background:rgba(0,200,150,0.1);border:1px solid rgba(0,200,150,0.3);border-radius:8px;padding:10px;text-align:center;color:var(--green);font-size:20px;font-weight:900;font-family:monospace;margin-top:6px}
.conv-note{color:var(--gray);font-size:11px;text-align:center;margin-top:6px}

/* SECTIONS */
.section{padding:44px 20px;max-width:1100px;margin:0 auto}
.section-title{text-align:center;margin-bottom:6px}
.section-title h2{font-size:clamp(20px,4vw,30px);font-weight:800}
.section-title p{color:var(--gray);margin-top:5px;font-size:13px}
.grid{display:grid;gap:12px;margin-top:24px}
.grid-2{grid-template-columns:repeat(auto-fit,minmax(260px,1fr))}
.grid-3{grid-template-columns:repeat(auto-fit,minmax(200px,1fr))}
.grid-4{grid-template-columns:repeat(auto-fit,minmax(150px,1fr))}

/* CARDS */
.card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:18px;transition:all .2s}
.card:hover{border-color:rgba(0,200,150,0.3);background:rgba(0,200,150,0.04)}
.card-icon{font-size:26px;margin-bottom:8px}
.card h3{font-size:14px;font-weight:700;margin-bottom:5px}
.card p{color:var(--gray);font-size:12px;line-height:1.5}

/* SERVICE GRID */
.service-item{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:14px;text-align:center;cursor:pointer;transition:all .2s}
.service-item:hover{border-color:var(--green);transform:translateY(-2px)}
.service-item .icon{font-size:22px;margin-bottom:6px}
.service-item .name{font-size:11px;font-weight:700;color:white}
.service-item .type{font-size:10px;color:var(--gray);margin-top:2px}

/* TAGS */
.tag{display:inline-block;background:rgba(0,200,150,0.12);color:var(--green);padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700}
.tag-gold{background:rgba(244,167,38,0.12);color:var(--gold)}
.tag-blue{background:rgba(26,86,219,0.15);color:#60A5FA}

/* MODALS */
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:200;align-items:center;justify-content:center;padding:20px}
.modal.open{display:flex}
.modal-box{background:var(--navy2);border:1px solid rgba(0,200,150,0.3);border-radius:16px;padding:24px;width:100%;max-width:400px;position:relative;max-height:90vh;overflow-y:auto}
.modal-close{position:absolute;top:10px;right:14px;background:none;border:none;color:var(--gray);font-size:18px;cursor:pointer}
.form-group{margin-bottom:12px}
.form-group label{display:block;font-size:11px;font-weight:600;color:var(--gray);margin-bottom:4px}
.form-group input,.form-group select{width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:white;padding:9px 12px;border-radius:8px;font-size:13px}
.form-group input:focus,.form-group select:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(0,200,150,.1)}
.form-group select option{background:var(--navy2)}
.msg{padding:9px 12px;border-radius:8px;font-size:12px;margin-bottom:10px}
.msg.success{background:rgba(0,200,150,0.15);color:var(--green);border:1px solid rgba(0,200,150,0.3)}
.msg.error{background:rgba(220,38,38,0.15);color:#F87171;border:1px solid rgba(220,38,38,0.3)}

/* PULSE */
.pulse{display:inline-block;width:8px;height:8px;background:var(--green);border-radius:50%;animation:pulse 2s infinite;margin-right:5px}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(0.8)}}

/* DIVIDER */
.divider{height:1px;background:rgba(255,255,255,0.06);margin:36px 0}

/* ECOBANK BANNER */
.ecobank-banner{background:linear-gradient(135deg,var(--navy2),#0D2B1A);border:1px solid rgba(0,200,150,0.3);border-radius:14px;padding:18px;margin-top:24px}
.iban{font-family:monospace;color:var(--green);font-size:13px;word-break:break-all;margin:6px 0}

/* DASHBOARD */
.dash-hidden{display:none}
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:18px}
.kpi{background:rgba(255,255,255,0.05);border-radius:12px;padding:14px;border-top:3px solid var(--green)}
.kpi-val{font-size:22px;font-weight:900;margin:5px 0}
.kpi-label{font-size:10px;color:var(--gray)}

/* TERMINAL */
.terminal-app{display:flex;height:calc(100vh - 58px);overflow:hidden;background:#f0f2f5}
.t-sidebar{width:200px;background:#1a1a2e;display:flex;flex-direction:column;flex-shrink:0}
.t-logo{display:flex;align-items:center;gap:8px;padding:16px;border-bottom:1px solid rgba(255,255,255,.08)}
.t-logo-text{font-size:15px;font-weight:700;color:#fff}
.t-nav{flex:1;padding:8px;display:flex;flex-direction:column;gap:2px}
.t-btn{display:flex;align-items:center;gap:8px;width:100%;padding:9px 10px;border:none;background:transparent;color:rgba(255,255,255,.6);border-radius:8px;text-align:left;font-size:12px;cursor:pointer;transition:all .15s}
.t-btn:hover{background:rgba(255,255,255,.08);color:#fff}
.t-btn.active{background:#4f46e5;color:#fff}
.t-main{flex:1;display:flex;flex-direction:column;overflow:hidden;color:#1a1a2e}
.t-topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:#fff;border-bottom:1px solid #e5e7eb;flex-shrink:0}
.t-title{font-size:14px;font-weight:600;color:#1a1a2e}
.t-panel{display:none;flex:1;overflow-y:auto;padding:20px}
.t-panel.active{display:block}

/* TERMINAL STYLES */
.t-stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.t-stat{background:#fff;border-radius:10px;padding:16px;border:1px solid #e5e7eb}
.t-stat-label{font-size:11px;color:#6b7280;margin-bottom:4px}
.t-stat-value{font-size:22px;font-weight:700;color:#1a1a2e;margin-bottom:3px}
.t-stat-change{font-size:10px;color:#059669}
.t-card{background:#fff;border-radius:10px;padding:16px;border:1px solid #e5e7eb;margin-bottom:14px}
.t-card-title{font-size:13px;font-weight:600;color:#374151;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid #f3f4f6}
.t-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.t-form-group{margin-bottom:12px}
.t-form-group label{display:block;font-size:11px;font-weight:500;color:#6b7280;margin-bottom:4px}
.t-form-group input,.t-form-group select{width:100%;padding:8px 10px;border:1px solid #dde1e7;border-radius:7px;background:#fff;color:#1a1a2e;font-size:13px}
.t-form-group input:focus,.t-form-group select:focus{border-color:#4f46e5;box-shadow:0 0 0 2px rgba(79,70,229,.1)}
.t-btn-primary{width:100%;padding:10px;font-size:14px;font-weight:600;border-radius:8px;border:none;background:#4f46e5;color:#fff;cursor:pointer}
.t-btn-secondary{padding:7px 14px;font-size:12px;font-weight:500;border-radius:7px;border:1.5px solid #d1d5db;background:#fff;color:#374151;cursor:pointer}
.t-method-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:8px}
.t-m-tile{border:1.5px solid #e5e7eb;border-radius:8px;padding:8px 4px;text-align:center;cursor:pointer;transition:all .15s;background:#fff}
.t-m-tile:hover{border-color:#a5b4fc;background:#f5f3ff}
.t-m-tile.selected{border-color:#4f46e5;background:#eef2ff}
.t-m-icon{font-size:18px;margin-bottom:3px}
.t-m-name{font-size:10px;font-weight:500;color:#374151}
.t-crypto-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:8px}
.t-c-tile{border:1.5px solid #e5e7eb;border-radius:8px;padding:8px;text-align:center;cursor:pointer;transition:all .15s;background:#fff}
.t-c-tile:hover{border-color:#f59e0b;background:#fffbeb}
.t-c-tile.selected{border-color:#d97706;background:#fef3c7}
.t-c-icon{font-size:20px;margin-bottom:3px}
.t-c-name{font-size:10px;font-weight:600;color:#374151}
.t-c-price{font-size:9px;color:#6b7280;margin-top:1px}
.t-gift-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:8px}
.t-g-tile{border:1.5px solid #e5e7eb;border-radius:8px;padding:8px 4px;text-align:center;cursor:pointer;transition:all .15s;background:#fff}
.t-g-tile:hover{border-color:#a5b4fc;background:#f5f3ff}
.t-g-tile.selected{border-color:#4f46e5;background:#eef2ff}
.t-badge{font-size:10px;padding:2px 8px;border-radius:10px;font-weight:500}
.t-badge-green{background:#d1fae5;color:#065f46}
.t-badge-blue{background:#dbeafe;color:#1e40af}
.t-badge-amber{background:#fef3c7;color:#92400e}
.t-tx-table{width:100%;border-collapse:collapse;font-size:12px}
.t-tx-table th{padding:10px 12px;text-align:left;font-size:11px;font-weight:600;color:#6b7280;background:#f9fafb;border-bottom:1px solid #e5e7eb}
.t-tx-table td{padding:10px 12px;color:#374151;border-bottom:1px solid #f3f4f6}
.t-tx-pos{color:#059669;font-weight:600}
.t-tx-neg{color:#dc2626;font-weight:600}
.t-tx-btc{color:#d97706;font-weight:600}
.t-tx-ok{background:#d1fae5;color:#065f46;font-size:10px;padding:2px 7px;border-radius:8px;font-weight:500}
.t-ticker-row{display:flex;gap:8px;overflow-x:auto;margin-bottom:16px;padding-bottom:3px}
.t-ticker-chip{background:#fff;border:1px solid #e5e7eb;border-radius:7px;padding:7px 12px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:2px}
.t-tc-sym{font-size:11px;font-weight:700;color:#1a1a2e}
.t-tc-price{font-size:11px;color:#374151}
.t-tc-chg{font-size:10px}
.t-tc-up{color:#059669}
.t-tc-dn{color:#dc2626}
.crypto-addr-box{background:#f8faff;border:1px solid #c7d2fe;border-radius:7px;padding:9px 12px;font-family:'Courier New',monospace;font-size:10px;color:#312e81;word-break:break-all;margin-bottom:7px}
.link-box{background:#f0f9ff;border:1px solid #bae6fd;border-radius:7px;padding:9px 12px;font-family:monospace;font-size:11px;color:#0369a1;word-break:break-all}
.t-sub-banner{background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;font-size:11px;color:#92400e;margin-bottom:16px}
.t-fee-table{display:flex;flex-direction:column;gap:5px}
.t-fee-row{display:flex;justify-content:space-between;font-size:12px;padding:5px 8px;background:#f9fafb;border-radius:5px}
.t-fee-row span:last-child{font-weight:600;color:#4f46e5}
.t-sec-line{font-size:10px;color:#059669;background:#d1fae5;padding:7px 10px;border-radius:7px;margin-bottom:12px}
.t-check-item{font-size:12px;padding:6px 10px;border-radius:7px;color:#065f46;background:#f0fdf4;margin-bottom:5px}
.t-setting-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f3f4f6;font-size:12px;color:#374151}
.t-toggle-on{font-size:10px;padding:2px 8px;border-radius:8px;font-weight:600;background:#d1fae5;color:#065f46}
.t-amount-hero{background:linear-gradient(135deg,#4f46e5,#818cf8);border-radius:10px;padding:16px;text-align:center;margin-bottom:16px;color:#fff}
.t-amount-label{font-size:11px;opacity:.8;margin-bottom:3px}
.t-amount-big{font-size:32px;font-weight:700}
.mini-tx-item{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #f3f4f6}
.mini-tx-icon{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
.mini-tx-icon.in{background:#d1fae5}
.mini-tx-icon.out{background:#fee2e2}
.mini-tx-icon.btc{background:#fef3c7}
.mini-tx-info{flex:1}
.mini-tx-label{font-size:11px;font-weight:500;color:#1a1a2e}
.mini-tx-date{font-size:10px;color:#9ca3af}
.mini-tx-amt{font-size:12px;font-weight:600}

/* ABONNEMENT */
.sub-card{background:linear-gradient(135deg,var(--navy2),#0D2B1A);border:1px solid rgba(244,167,38,0.4);border-radius:14px;padding:20px;margin-bottom:14px}

/* FOOTER */
footer{background:var(--navy2);border-top:1px solid rgba(255,255,255,0.06);padding:36px 20px;text-align:center}

@media(max-width:700px){
  .t-sidebar{width:54px}
  .t-logo-text,.t-btn span:last-child{display:none}
  .t-stats-grid{grid-template-columns:repeat(2,1fr)}
  .t-grid-2{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo" onclick="showScreen('home')">Omni<span>pay</span><small>BÉNIN</small></div>
  <div class="nav-links">
    <button class="lang-btn active" onclick="setLang('fr',this)">FR</button>
    <button class="lang-btn" onclick="setLang('en',this)">EN</button>
    <button class="lang-btn" onclick="setLang('pt',this)">PT</button>
    <button class="nav-btn" id="mainNavBtn" onclick="handleNavBtn()">Connexion</button>
  </div>
</nav>

<!-- TICKER -->
<div class="ticker-wrap">
  <div class="ticker">
    <span>📊 1 EUR = 655.96 FCFA</span><span>📊 1 USD = 601.45 FCFA</span>
    <span>📊 1 GBP = 761.20 FCFA</span><span>₿ BTC = 80,920 USD</span>
    <span>💎 USDT = 1.00 USD</span><span>🥜 Cajou: 850 FCFA/kg</span>
    <span>🌽 Maïs: 180 FCFA/kg</span><span>🫘 Soja: 320 FCFA/kg</span>
    <span>💳 Commission Omnipay: 2.5%</span><span>🌍 omnipay-eu.com</span>
    <span>📊 1 EUR = 655.96 FCFA</span><span>📊 1 USD = 601.45 FCFA</span>
    <span>📊 1 GBP = 761.20 FCFA</span><span>₿ BTC = 80,920 USD</span>
    <span>💎 USDT = 1.00 USD</span><span>🥜 Cajou: 850 FCFA/kg</span>
    <span>🌽 Maïs: 180 FCFA/kg</span><span>🫘 Soja: 320 FCFA/kg</span>
    <span>💳 Commission Omnipay: 2.5%</span><span>🌍 omnipay-eu.com</span>
  </div>
</div>

<!-- SCREEN: HOME -->
<div id="screen-home" class="screen active">
  <!-- HERO -->
  <div class="hero">
    <div style="position:relative">
      <div class="hero-badge">🌍 Bénin · Afrique · Europe · Monde</div>
      <h1>Omni<span>pay</span></h1>
      <p class="hero-sub" id="hero-sub">Une autre finance est possible.</p>
      <p class="hero-sub2" id="hero-sub2">Honnête. Africaine. Mondiale. 🇧🇯</p>
      <div class="hero-btns">
        <button class="btn-gold" onclick="openModal('signupModal')">🚀 Créer mon compte</button>
        <button class="btn-secondary" onclick="openModal('loginModal')">Connexion</button>
      </div>
      <div class="converter">
        <p class="conv-h">⚡ CONVERTISSEUR EN DIRECT</p>
        <div class="conv-row">
          <input class="conv-input" type="number" id="convAmount" value="100000" oninput="convert()">
          <select class="conv-select" id="convFrom" onchange="convert()">
            <option>FCFA</option><option>EUR</option><option>USD</option>
            <option>GBP</option><option>CAD</option><option>BTC</option><option>USDT</option>
          </select>
        </div>
        <select class="conv-select" id="convTo" onchange="convert()" style="margin-bottom:8px">
          <option>EUR</option><option>FCFA</option><option>USD</option>
          <option>GBP</option><option>USDT</option><option>BTC</option>
        </select>
        <div class="conv-result" id="convResult">152.45 EUR</div>
        <p class="conv-note">Commission Omnipay: 2.5% · Transparent & Honnête</p>
      </div>
    </div>
  </div>

  <div style="background:#080F1E">
    <!-- TRANSFERTS -->
    <div class="section">
      <div class="section-title"><h2>💸 Transferts & Paiements</h2><p>Envoie et reçois partout dans le monde</p></div>
      <div class="grid grid-4" style="margin-top:20px">
        <div class="service-item"><div class="icon">📱</div><div class="name">MTN MoMo</div><div class="type">Mobile Money</div></div>
        <div class="service-item"><div class="icon">📞</div><div class="name">Moov Money</div><div class="type">Mobile Money</div></div>
