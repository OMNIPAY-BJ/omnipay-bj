    <p style="text-align:center;margin-top:12px;font-size:12px;color:var(--gray)">Pas de compte ? <a onclick="closeModal('loginModal');openModal('signupModal')" style="color:var(--green);cursor:pointer;font-weight:600">Créer un compte</a></p>
