    <p style="text-align:center;margin-top:12px;font-size:12px;color:var(--gray)">Déjà inscrit ? <a onclick="closeModal('signupModal');openModal('loginModal')" style="color:var(--green);cursor:pointer;font-weight:600">Se connecter</a></p>
  </div>
</div>

<script>
// ===== CONFIG =====
const ADMIN_EMAIL = 'regisagnikpe2002@gmail.com';
const ADMIN_PASS = 'OmniPay2026!Regis';
const RATES = {FCFA:1,EUR:655.96,USD:601.45,GBP:761.20,CAD:445.30,BTC:36000000,USDT:601.45};
const CRYPTO_PRICES = {BTC:{price:87420,chg:+2.4},ETH:{price:3210,chg:+1.8},USDT:{price:0.92,chg:-0.1},USDC:{price:0.92,chg:0.0},LTC:{price:78.40,chg:-0.6},XRP:{price:0.52,chg:+3.1}};
let currentUser = null;
let tState = {method:'CB/Visa',crypto:{sym:'BTC',name:'Bitcoin',price:87420},gift:'Transcash'};

const SAMPLE_TX = [
  {date:'02/07/2026 10:14',desc:'Bitcoin reçu — 900114 BTC',method:'Bitcoin',country:'International',status:'ok',amount:+99.67,type:'crypto'},
  {date:'02/07/2026 09:42',desc:'Virement Ecobank reçu',method:'Ecobank',country:'Bénin',status:'ok',amount:+350000,type:'in'},
  {date:'01/07/2026 18:10',desc:'Transfert MoMo envoyé',method:'MTN MoMo',country:'Bénin',status:'ok',amount:-50000,type:'out'},
  {date:'01/07/2026 15:33',desc:'Ethereum reçu — 0.031 ETH',method:'Ethereum',country:'International',status:'ok',amount:+151,type:'crypto'},
  {date:'01/07/2026 12:05',desc:'PayPal reçu',method:'PayPal',country:'France',status:'ok',amount:+215.00,type:'in'},
  {date:'30/06/2026 17:44',desc:'Transfert Wise international',method:'Wise',country:'Sénégal',status:'ok',amount:+320.000,type:'in'},
  {date:'30/06/2026 14:30',desc:'Rechargement Transcash',method:'Transcash',country:'France',status:'ok',amount:-7000,type:'gift'},
];

// ===== LANG =====
const L = {
  fr:{sub:'Une autre finance est possible.',sub2:'Honnête. Africaine. Mondiale. 🇧🇯'},
  en:{sub:'A different kind of finance.',sub2:'Honest. African. Global. 🇧🇯'},
  pt:{sub:'Outra finança é possível.',sub2:'Honesta. Africana. Global. 🇧🇯'}
};
function setLang(l,btn){
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('hero-sub').textContent=L[l].sub;
  document.getElementById('hero-sub2').textContent=L[l].sub2;
}

// ===== SCREENS =====
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+id).classList.add('active');
  window.scrollTo(0,0);
  if(id==='admin') updateAdminDash();
}

// ===== CONVERTER =====
function convert(){
  const a=parseFloat(document.getElementById('convAmount').value)||0;
  const f=document.getElementById('convFrom').value;
  const t=document.getElementById('convTo').value;
  const r=(a/RATES[f]*RATES[t]).toFixed(f==='BTC'||t==='BTC'?8:2);
  document.getElementById('convResult').textContent=r+' '+t;
}
convert();

// ===== MODALS =====
function openModal(id){document.getElementById(id).classList.add('open')}
function closeModal(id){document.getElementById(id).classList.remove('open')}
window.onclick=e=>{if(e.target.classList.contains('modal'))e.target.classList.remove('open')}

// ===== NAV BTN =====
function handleNavBtn(){
  if(currentUser){
    if(currentUser.role==='admin') showScreen('admin');
    else showScreen('client');
  } else {
    openModal('loginModal');
  }
}

// ===== AUTH =====
function handleLogin(){
  const email=document.getElementById('loginEmail').value.trim();
  const pass=document.getElementById('loginPass').value;
  if(!email||!pass){showMsg('loginMsg','Remplis tous les champs','error');return}
  if(email===ADMIN_EMAIL&&pass===ADMIN_PASS){
    currentUser={role:'admin',name:'Agnikpe Régis OLATOUNDE',email};
    closeModal('loginModal');
    document.getElementById('mainNavBtn').textContent='Admin 👑';
    showScreen('admin');
    return;
  }
  const users=JSON.parse(localStorage.getItem('op_users')||'[]');
  const u=users.find(x=>x.email===email&&x.pass===pass);
  if(u){
    currentUser=u;
    closeModal('loginModal');
    document.getElementById('mainNavBtn').textContent='Mon compte';
    document.getElementById('clientWelcome').textContent='Bienvenue, '+u.name.split(' ')[0]+' 👋';
    document.getElementById('clientRefCode').textContent=u.ref;
    showScreen('client');
  } else {
    showMsg('loginMsg','Email ou mot de passe incorrect','error');
  }
}

function handleSignup(){
  const name=document.getElementById('signupName').value.trim();
  const email=document.getElementById('signupEmail').value.trim();
  const phone=document.getElementById('signupPhone').value.trim();
  const country=document.getElementById('signupCountry').value.trim()||'FRANCE';
  const pass=document.getElementById('signupPass').value;
  if(!name||!email||!pass){showMsg('signupMsg','Tous les champs sont requis','error');return}
  const users=JSON.parse(localStorage.getItem('op_users')||'[]');
  if(users.find(x=>x.email===email)){showMsg('signupMsg','Email déjà utilisé','error');return}
  const ref='OMP-'+Math.random().toString(36).substr(2,6).toUpperCase();
  const u={name,email,phone,country,pass,ref,role:'client',joined:new Date().toLocaleDateString('fr')};
  users.push(u);
  localStorage.setItem('op_users',JSON.stringify(users));
  showMsg('signupMsg','✅ Compte créé ! Bienvenue sur Omnipay !','success');
  setTimeout(()=>{
    currentUser=u;
    closeModal('signupModal');
    document.getElementById('mainNavBtn').textContent='Mon compte';
    
